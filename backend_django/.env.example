# Copia este archivo a .env y completa los valores reales.
# Nunca commitear .env (ya está en .gitignore).

SECRET_KEY=change-me-dev-only
DEBUG=True

# PostgreSQL (obligatorio, no hay fallback a SQLite)
DB_NAME=web_electro
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Producción: Redis compartido para caché y rate limiting.
REDIS_URL=redis://127.0.0.1:6379/1

# WhatsApp (Evolution API) para notificación de contacto
EVOLUTION_API_URL=
EVOLUTION_API_TOKEN=
ADMIN_NUMBER=
# Máximo de segundos para la notificación síncrona de contacto.
CONTACT_NOTIFICATION_TIMEOUT=5

# Email (recuperación de contraseña)
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Frontend
FRONTEND_URL=http://127.0.0.1:5173

# Solo producción. Debe ser el origen que realmente sirve /media/ con tipo MIME
# de imagen; actualmente es el host de la API, no el frontend.
MEDIA_PUBLIC_BASE_URL=https://api.adictosaltechno.com
