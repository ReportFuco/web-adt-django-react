# Copia este archivo a .env y completa los valores reales.
# Nunca commitear .env (ya está en .gitignore).

SECRET_KEY=change-me-dev-only
DEBUG=True

# PostgreSQL (obligatorio, no hay fallback a SQLite)
DB_NAME=web_electro
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Mercado Pago (store, actualmente sin rutas en el frontend)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# WhatsApp (Evolution API) para notificación de contacto
EVOLUTION_API_URL=
EVOLUTION_API_TOKEN=
ADMIN_NUMBER=

# Email (recuperación de contraseña)
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Frontend
FRONTEND_URL=http://127.0.0.1:5173

# Solo producción (URL pública de medios servidos fuera de DEBUG)
MEDIA_PUBLIC_BASE_URL=
